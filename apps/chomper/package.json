{
  "name": "chomper",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "ingest": "tsx --env-file=../../packages/db/.env src/cli.ts",
    "bulk-ingest": "tsx --env-file=../../packages/db/.env src/bulk-ingest.ts",
    "recalcMVP": "tsx --env-file=../../packages/db/.env src/recalc-mvp.ts",
    "test": "tsx src/test-suite.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=esm --outfile=dist/index.mjs --external:@aws-sdk/*",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@lfstats/db": "workspace:*"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^25.9.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
